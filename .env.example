# Database Configuration
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=gateway
DATABASE_SYNCHRONIZE=true

# Node Environment
NODE_ENV=development
PORT=3000

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=3600

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting (Throttling)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Email Configuration
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@paymentgateway.com
EMAIL_REPLY_TO=support@paymentgateway.com

# SendGrid Configuration (for production)
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@paymentgateway.com
SENDGRID_FROM_NAME=Payment Gateway

# Nodemailer Configuration (SMTP-based email)
NODEMAILER_HOST=smtp.gmail.com
NODEMAILER_PORT=587
NODEMAILER_SECURE=false
NODEMAILER_USER=your-email@gmail.com
NODEMAILER_PASS=your-app-password
